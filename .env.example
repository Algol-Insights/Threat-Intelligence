# ── Chengeto CTI Platform — Environment Configuration ──────────────────────
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Security (CHANGE THESE IN PRODUCTION) ──────────────────────────────────
JWT_SECRET=your-random-secret-key-at-least-32-chars
ADMIN_PASSWORD=Chengeto@2026!

# ── AI Model API Keys (at least one required for live analysis) ────────────
# Get free: https://aistudio.google.com/apikey
GEMINI_API_KEY= AIzaSyCmdx-8HQlW4T6oqDi9RkYaTHwGjBr3IOs

# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Get free: https://console.groq.com/keys
GROQ_API_KEY=

# ── Organization Context ───────────────────────────────────────────────────
# Options: financial, government, telecom, healthcare, education, general
ORG_SECTOR=general

# ── Ports (usually leave as default) ───────────────────────────────────────
PORT=8080
SYSLOG_PORT=1514

# ── Network Scanning ──────────────────────────────────────────────────────
SCAN_INTERVAL=120000
